		annotation PBI_FormatHint = {"isGeneralNumber":true}

	/// Indica si el activo esta afectado por la deprecacion.
	column is_affected
		dataType: boolean
		isHidden
		formatString: """TRUE"";""TRUE"";""FALSE"""
		lineageTag: bb9f9a41-c619-496d-9be2-0f304fc63119
