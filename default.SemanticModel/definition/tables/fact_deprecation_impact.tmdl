table fact_deprecation_impact
	lineageTag: b2418c86-1eec-4385-bb62-8a3022e366e4
	sourceLineageTag: [dbo].[fact_deprecation_impact]

	/// Total de registros de impacto por deprecación.
	measure 'Impactos de Deprecacion' = COUNTROWS ( fact_deprecation_impact )
		lineageTag: 8a5891d3-443e-4377-8aa9-28ed9547560b

	/// Activos distintos afectados por deprecación.
	measure 'Activos Afectados' = CALCULATE ( DISTINCTCOUNT ( fact_deprecation_impact[asset_sk] ), fact_deprecation_impact[is_affected] = TRUE () )
		lineageTag: 3d022a94-811f-457a-9902-26bd0d7c3fbe

	/// Proporción de activos afectados respecto al inventario.
	measure '% Activos Afectados' = DIVIDE ( [Activos Afectados], [Activos Inventario] )
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: c9c75f44-b508-4e57-80af-ce41125a38b5

	/// Riesgo promedio de impactos de deprecación.
	measure 'Riesgo Promedio' = AVERAGE ( fact_deprecation_impact[risk_score] )
		formatString: 0.00
		lineageTag: 58f67170-0455-4ea1-9ebf-1269aaa94999

	/// Promedio de días a retiro para tecnologías afectadas.
	measure 'Dias Promedio a Retiro' = AVERAGE ( fact_deprecation_impact[days_to_retirement] )
		formatString: 0.00
		lineageTag: 8b557ea7-7f3b-49a0-ab4e-50b3919c1838

	/// Cantidad de alertas con riesgo critico (risk_band_sk = 1).
	measure 'Alertas Criticas' = CALCULATE([Impactos de Deprecacion], 'fact_deprecation_impact'[risk_band_sk] = "1")
		formatString: #,0
		lineageTag: c320895f-825c-475a-9107-3a8fb623d9b4

	/// Cantidad de tecnologias unicas afectadas por deprecacion.
	measure 'Tecnologias Afectadas' = DISTINCTCOUNT('fact_deprecation_impact'[technology_sk])
		formatString: #,0
		lineageTag: 14df1271-a779-418c-be01-01f157d1a82d

	/// Minimo de dias a retiro entre los impactos activos.
	measure 'Minimos Dias a Retiro' =
			CALCULATE(
			    MIN('fact_deprecation_impact'[days_to_retirement]),
			    'fact_deprecation_impact'[days_to_retirement] > 0
			)
		formatString: #,0
		lineageTag: 06360286-5e2b-4bc3-82aa-00cc92b6677e

